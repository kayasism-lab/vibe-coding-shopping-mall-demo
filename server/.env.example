PORT=5000

# MongoDB Atlas connection string.
# In production, prefer the Atlas URL. If omitted, the app falls back to local MongoDB.
MONGODB_ATLAS_URL=mongodb://username:password@host1:27017,host2:27017,host3:27017/shopping_mall_demo?ssl=true&authSource=admin&replicaSet=your-replica-set&retryWrites=true&w=majority&appName=Cluster0

# Auth
JWT_SECRET=replace_with_a_secure_random_secret
JWT_EXPIRES_IN=1h

# Toss Payments server secret key
TOSS_SECRET_KEY=test_sk_replace_me

# Optional seeded admin account
ADMIN_EMAIL=admin@moonatelier.com
ADMIN_PASSWORD=change_me
ADMIN_NAME=Moon Admin
