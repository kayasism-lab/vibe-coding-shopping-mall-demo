# Copy this file to `.env` and replace the placeholder values.
# Vite reads only variables prefixed with VITE_. Restart `npm run dev` after changes.

# Backend API
# Local example: http://localhost:5000
# Production example: https://your-cloudtype-domain
VITE_API_BASE_URL=http://localhost:5000

# Toss Payments client key
# Test key example: test_ck_...
VITE_TOSS_CLIENT_KEY=your_toss_client_key

# Cloudinary Upload Widget (Search page)
# Cloud name: Cloudinary console → Dashboard → Account Details
# Upload preset: Settings → Upload → Upload presets → create unsigned preset for client-side upload
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset_name
